{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdTool",
  "version": "0.1.0",
  "identifier": "com.mdtool.structurefixer",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "mdTool",
